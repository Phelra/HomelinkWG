###############################################################################
# HomelinkWG — fichier de configuration d'environnement
# Copier vers .env et remplir les valeurs
#   cp .env.example .env
###############################################################################

# ─────────────────────────────────────────────────────────────────────────────
#  OBLIGATOIRES
# ─────────────────────────────────────────────────────────────────────────────

# Mot de passe admin — deux façons de le définir (choisir une seule) :

# Option 1 (simple) : mot de passe en clair, hashé automatiquement au démarrage
ADMIN_PASSWORD=monmotdepasse

# Option 2 (avancé) : hash bcrypt pré-généré
# Générer avec : python3 -c "import bcrypt; print(bcrypt.hashpw(b'VOTRE_MDP', bcrypt.gensalt()).decode())"
# ADMIN_PASSWORD_HASH=$2b$12$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────
#  OPTIONNELS
# ─────────────────────────────────────────────────────────────────────────────

# Port du dashboard (défaut : 5555)
DASHBOARD_PORT=5555

# Adresse de bind du dashboard (défaut : 0.0.0.0)
DASHBOARD_HOST=0.0.0.0

# Nom de l'interface WireGuard (défaut : wg0)
WG_INTERFACE=wg0

# Chemin absolu vers votre fichier wg0.conf sur le HOST
# (sera monté en lecture seule dans le conteneur)
WG_CONFIG_FILE=./yourconfwg/wg0.conf

# Activer les analytics SQLite (défaut : true)
ANALYTICS_ENABLED=true

# Fuseau horaire (défaut : UTC)
TZ=Europe/Paris

# ─────────────────────────────────────────────────────────────────────────────
#  OPTIONNELS — Debug
# ─────────────────────────────────────────────────────────────────────────────

# Mode allégé — réduit le rafraîchissement UI et les sondes réseau (défaut : false)
# Utile sur des petits serveurs / Raspberry Pi
LIGHT_MODE=false

# Mode ultra-allégé — encore moins de travail, analytics désactivés (défaut : false)
ULTRA_LIGHT=false

# Niveau de log supervisord : debug | info | warn | error
LOG_LEVEL=info

# Ne pas modifier pour Docker : le dashboard utilise supervisord au lieu de systemd
HomelinkWG_RUNTIME=docker
